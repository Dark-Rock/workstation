{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#d3d7cf",
    "closer": "p:os",
    "pink": "#F5BDE6",
    "lavender": "#919bff",
    "purple": "#821be3",
    "blue": "#7aa2f7",
    "green": "#a6da95",
    "teal": "#8bd5ca",
    "orange": "#f5a97f",
    "yellow": "#eed49f",
    "slate": "#6e738d",
    "danger": "#ed8796",
    "ok": "#a6da95"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:os",
          "foreground": "#000000",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "#ffffff",
          "background": "#c386f1",
          "template": "{{ if .SSHSession }} SSH{{ end }}"
        },
        {
          "background": "p:purple",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b4",
          "options": {
            "home_icon": "~",
            "style": "agnoster_short",
            "max_depth": 2
          },
          "style": "powerline",
          "template": " \uf07c {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:pink",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b4",
          "options": {
            "branch_icon": "\uf126 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "type": "project",
          "foreground": "#000000",
          "background": "#ffeb3b",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Version }} {{.Version}}{{ end }}{{ end }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "p:lavender",
          "foreground": "#ffffff",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} \ue718 ",
          "type": "node"
        },
        {
          "background": "p:blue",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue627 ",
          "type": "go"
        },
        {
          "background": "p:teal",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue235 ",
          "type": "python"
        },
        {
          "background": "p:pink",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "display_mode": "files",
            "fetch_version": true
          },
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue791 ",
          "type": "ruby"
        },
        {
          "background": "p:orange",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "display_default": false
          },
          "style": "powerline",
          "template": " {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} \ue7ad ",
          "type": "aws"
        },
        {
          "background": "p:danger",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "display_error": false
          },
          "style": "powerline",
          "template": " \u2388 {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}} ",
          "type": "kubectl"
        },
        {
          "background": "p:slate",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "style": "powerline",
          "template": " \uf0ad ",
          "type": "root"
        },
        {
          "background": "p:yellow",
          "foreground": "#000000",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "threshold": 500
          },
          "style": "powerline",
          "template": " {{ .FormattedMs }} \uf252 ",
          "type": "executiontime"
        },
        {
          "background": "p:green",
          "foreground": "#111111",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b6",
          "options": {
            "always_enabled": true
          },
          "style": "powerline",
          "template": " {{ if gt .Code 0 }}{{ reason .Code }}{{ else }}\uf42e{{ end }} ",
          "type": "status"
        },
        {
          "background": "p:os",
          "foreground": "#000000",
          "invert_powerline": true,
          "style": "diamond",
          "template": " {{ .CurrentDate | date \"15:04\" }} \uf017 ",
          "trailing_diamond": "\ue0b4",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#d3d7cf",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "transient_prompt": {
    "foreground": "#c6a0f6",
    "background": "transparent",
    "template": "❯ "
  },
  "final_space": true,
  "version": 4
}
