root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json,jsonc}]
indent_size = 2

[justfile]
indent_style = space
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4
